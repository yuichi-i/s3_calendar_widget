            android:layout_weight="1" android:gravity="center" android:text="25"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_3_4" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="26"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_3_5" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="27"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_3_6" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="28"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FF4488FF"/>
    </LinearLayout>
    <!-- 陦・: 鄙梧怦3/1(譌･)縲・/7(蝨・・郁埋濶ｲ・・-->
    <LinearLayout android:id="@+id/row4" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <TextView android:id="@+id/day_4_0" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="1"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#66FF4444"/>
        <TextView android:id="@+id/day_4_1" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="2"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#66FFFFFF"/>
        <TextView android:id="@+id/day_4_2" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="3"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#66FFFFFF"/>
        <TextView android:id="@+id/day_4_3" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="4"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#66FFFFFF"/>
        <TextView android:id="@+id/day_4_4" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="5"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#66FFFFFF"/>
        <TextView android:id="@+id/day_4_5" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="6"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#66FFFFFF"/>
        <TextView android:id="@+id/day_4_6" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="7"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#664488FF"/>
