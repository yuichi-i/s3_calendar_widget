            android:layout_weight="1" android:gravity="center" android:text="5"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_0_5" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="6"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_0_6" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="7"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FF4488FF"/>
    </LinearLayout>
    <!-- 陦・: 8(譌･)縲・4(蝨・ 11=蟒ｺ蝗ｽ險伜ｿｵ譌･(襍､) -->
    <LinearLayout android:id="@+id/row1" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <TextView android:id="@+id/day_1_0" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="8"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFF4444"/>
        <TextView android:id="@+id/day_1_1" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="9"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_1_2" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="10"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_1_3" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="11"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFF4444"/>
