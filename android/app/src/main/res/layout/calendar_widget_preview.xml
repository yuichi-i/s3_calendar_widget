            android:layout_weight="1" android:gravity="center" android:text="12"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_1_5" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="13"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_1_6" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="14"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FF4488FF"/>
    </LinearLayout>
    <!-- 陦・: 15(譌･)縲・1(蝨・ -->
