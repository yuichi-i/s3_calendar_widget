<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF000000"
    android:padding="4dp">

    <!-- 譛医・繝・ム繝ｼ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_month_year"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2026蟷ｴ 2譛・
            android:textColor="#FFFFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="4dp"
            android:paddingBottom="3dp" />
    </LinearLayout>

    <!-- 譖懈律繝倥ャ繝繝ｼ陦・-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">

        <TextView android:id="@+id/tv_dow0" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:gravity="center" android:text="譌･"
            android:textColor="#FFFF4444" android:textSize="9sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_dow1" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:gravity="center" android:text="譛・
            android:textColor="#FFFFFFFF" android:textSize="9sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_dow2" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:gravity="center" android:text="轣ｫ"
            android:textColor="#FFFFFFFF" android:textSize="9sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_dow3" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:gravity="center" android:text="豌ｴ"
            android:textColor="#FFFFFFFF" android:textSize="9sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_dow4" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:gravity="center" android:text="譛ｨ"
            android:textColor="#FFFFFFFF" android:textSize="9sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_dow5" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:gravity="center" android:text="驥・
            android:textColor="#FFFFFFFF" android:textSize="9sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_dow6" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1"
            android:gravity="center" android:text="蝨・
            android:textColor="#FF4488FF" android:textSize="9sp" android:textStyle="bold"/>
    </LinearLayout>

    <!-- 蛹ｺ蛻・ｊ邱・-->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:text="" />

    <!-- 繧ｫ繝ｬ繝ｳ繝繝ｼ繧ｰ繝ｪ繝・ラ・・陦古・蛻暦ｼ・-->
    <!-- 2026蟷ｴ2譛・ 1譌･=譌･譖・ 28譌･縺ｾ縺ｧ -->
    <!-- 陦・: 1(譌･)縲・(蝨・ -->
    <LinearLayout android:id="@+id/row0" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
        <TextView android:id="@+id/day_0_0" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="1"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFF4444"/>
        <TextView android:id="@+id/day_0_1" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="2"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_0_2" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="3"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_0_3" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="4"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
