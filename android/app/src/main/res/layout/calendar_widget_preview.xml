        <TextView android:id="@+id/day_2_2" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="17"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_2_3" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="18"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_2_4" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="19"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
        <TextView android:id="@+id/day_2_5" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:text="20"
            android:textSize="13sp" android:textStyle="italic|bold" android:textColor="#FFFFFFFF"/>
